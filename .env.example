# ----------------------------------------------------------------------------
# PlayGG Cafe Booking API — environment variables
# Copy to `.env` and adjust. All values have safe local defaults, so the app
# runs out of the box with SQLite even without a .env file.
# ----------------------------------------------------------------------------

# Database. Defaults to local SQLite. For production set a Postgres URL, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/playgg
# DATABASE_URL=sqlite:///./playgg.db

# JWT auth (bonus)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Seeded demo admin used to obtain a token via POST /login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=playgg123

# Operating hours used to generate hourly booking slots (24h clock)
OPENING_HOUR=10
CLOSING_HOUR=22
